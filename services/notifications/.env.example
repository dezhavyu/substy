APP_NAME=notifications-service
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8091
APP_LOG_LEVEL=INFO
APP_JSON_LOGS=true

DB_HOST=postgres
DB_PORT=5432
DB_NAME=notifications
DB_USER=notifications
DB_PASSWORD=notifications
DB_MIN_POOL_SIZE=3
DB_MAX_POOL_SIZE=20

NATS_URL=nats://nats:4222
NATS_CONNECT_TIMEOUT=5
NATS_STREAM_NAME=NOTIFICATIONS
NATS_SUBJECT_NOTIFICATION_CREATED=notification.created.v1
OUTBOX_BATCH_SIZE=100
OUTBOX_PUBLISH_INTERVAL_SECONDS=2

PAYLOAD_MAX_BYTES=65536
PAYLOAD_MAX_DEPTH=8

OTEL_ENABLED=false
OTEL_SERVICE_NAME=notifications-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
