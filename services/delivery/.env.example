APP_NAME=delivery-service
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8092
APP_LOG_LEVEL=INFO
APP_JSON_LOGS=true

DB_HOST=postgres
DB_PORT=5432
DB_NAME=delivery
DB_USER=delivery
DB_PASSWORD=delivery
DB_MIN_POOL_SIZE=3
DB_MAX_POOL_SIZE=20

REDIS_URL=redis://redis:6379/0

NATS_URL=nats://nats:4222
NATS_CONNECT_TIMEOUT=5
NATS_STREAM_NAME=NOTIFICATIONS
NATS_SUBJECT_NOTIFICATION_CREATED=notification.created.v1
NATS_SUBJECT_DELIVERY_SUCCEEDED=delivery.succeeded.v1
NATS_SUBJECT_DELIVERY_FAILED=delivery.failed.v1
NATS_CONSUMER_NAME=delivery-service
NATS_DURABLE_NAME=delivery-service

SUBSCRIPTIONS_INTERNAL_URL=http://subscriptions-service:8090
SUBSCRIPTIONS_PAGE_LIMIT=100
SUBSCRIPTIONS_FETCH_CONCURRENCY=3

DELIVERY_MAX_ATTEMPTS=5
DELIVERY_BASE_DELAY_SECONDS=5
DELIVERY_MAX_DELAY_SECONDS=3600
DELIVERY_RETRY_JITTER_SECONDS=5
DELIVERY_CHANNELS=push,email,web

PROVIDER_STUB_FAIL_RATE=0.0

OTEL_ENABLED=false
OTEL_SERVICE_NAME=delivery-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
