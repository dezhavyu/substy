APP_ENV=dev
APP_LOG_LEVEL=INFO
APP_JSON_LOGS=true

POSTGRES_USER=substy
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=substy

JWT_ALGORITHM=HS256
JWT_ISSUER=auth-service
JWT_AUDIENCE=substy
JWT_SECRET=change-me-super-secret-at-least-32-bytes
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_SECONDS=7200
REFRESH_TOKEN_PEPPER=change-me-refresh-token-pepper

RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_PER_MINUTE=30
RATE_LIMIT_USER_PER_MINUTE=120

NATS_STREAM_NAME=NOTIFICATIONS
NATS_SUBJECT_NOTIFICATION_CREATED=notification.created.v1
NATS_SUBJECT_DELIVERY_SUCCEEDED=delivery.succeeded.v1
NATS_SUBJECT_DELIVERY_FAILED=delivery.failed.v1

OUTBOX_BATCH_SIZE=100
OUTBOX_PUBLISH_INTERVAL_SECONDS=2
SCHEDULER_BATCH_SIZE=200
SCHEDULER_TICK_INTERVAL_SECONDS=2
PROVIDER_STUB_FAIL_RATE=0.0

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

BFF_HOST_PORT=8070
FRONTEND_HOST_PORT=3000
NEXT_PUBLIC_API_URL=http://bff-gateway:8070
NEXT_PUBLIC_TOPICS_PAGE_SIZE=20
NEXT_PUBLIC_INBOX_PAGE_SIZE=20

FRONTEND_DIR=../substy_web/notification-platform-frontend
E2E_SUBSCRIPTIONS_URL=http://localhost:8090
E2E_ADMIN_USER_ID=00000000-0000-0000-0000-000000000001
